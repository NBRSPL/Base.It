<uiw:AppWindow xmlns="https://github.com/avaloniaui"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:vm="using:Base.It.App.ViewModels"
               xmlns:v="using:Base.It.App.Views"
               xmlns:cfg="using:Base.It.Core.Config"
               xmlns:ui="using:FluentAvalonia.UI.Controls"
               xmlns:uiw="using:FluentAvalonia.UI.Windowing"
               x:Class="Base.It.App.MainWindow"
               x:DataType="vm:MainWindowViewModel"
               Width="1240" Height="760"
               MinWidth="960" MinHeight="560"
               Title="Base.it"
               WindowStartupLocation="CenterScreen"
               Background="{DynamicResource App.WindowBgBrush}">

    <Panel>
        <ui:NavigationView x:Name="Nav"
                           PaneDisplayMode="Left"
                           IsSettingsVisible="False"
                           IsBackButtonVisible="False"
                           IsPaneToggleButtonVisible="True"
                           OpenPaneLength="210">

            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem Content="Home"    Tag="Home"    IconSource="Home"/>
                <ui:NavigationViewItem Content="Compare" Tag="Compare" IconSource="AllApps"/>
                <ui:NavigationViewItem Content="Sync"    Tag="Sync"    IconSource="Sync"/>
                <ui:NavigationViewItem Content="Batch"   Tag="Batch"   IconSource="List"/>
                <ui:NavigationViewItem Content="Scripts" Tag="Scripts" IconSource="Document"/>
                <ui:NavigationViewItem Content="Query"   Tag="Query"   IconSource="Find"/>
                <ui:NavigationViewItem Content="Watch"   Tag="Watch"   IconSource="View"/>
            </ui:NavigationView.MenuItems>

            <ui:NavigationView.FooterMenuItems>
                <ui:NavigationViewItem Content="Settings" Tag="Settings" IconSource="Settings"/>
            </ui:NavigationView.FooterMenuItems>

            <!-- Pane footer: theme toggle. Aligned LEFT with the same
                 horizontal indent Fluent uses for its nav item icons, so
                 it visually belongs to the stack instead of floating in
                 the middle of the pane. The icon itself is 40×40 (same
                 footprint as a nav item's icon area) with no background
                 until hovered — it still reads as an icon button, not
                 a full-width tab. PaneFooter renders just above the
                 FooterMenuItems (Settings), keeping the toggle adjacent
                 to Settings without fake-looking like a nav entry. -->
            <ui:NavigationView.PaneFooter>
                <!-- Theme toggle. Stretches to match the nav item width when
                     the pane is expanded (showing "Theme" label next to the
                     icon), collapses to a pure 40×40 icon button when the
                     pane is collapsed. Icon stays in the same 40-wide gutter
                     so it aligns with nav item icons above. -->
                <Border HorizontalAlignment="Stretch" Padding="4,0,4,2">
                    <Button x:Name="ThemeToggleBtn"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            VerticalContentAlignment="Center"
                            MinHeight="40"
                            Padding="0"
                            CornerRadius="4"
                            Background="Transparent"
                            BorderThickness="0"
                            ToolTip.Tip="Toggle Dark / Light theme"
                            Click="OnToggleTheme">
                        <Grid ColumnDefinitions="40,*">
                            <TextBlock x:Name="ThemeGlyph" Grid.Column="0"
                                       Text="☾" FontSize="16"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{DynamicResource App.TextSecondaryBrush}"/>
                            <TextBlock x:Name="ThemeLabel" Grid.Column="1"
                                       Text="Theme" FontSize="13"
                                       VerticalAlignment="Center"
                                       IsVisible="{Binding IsPaneOpen, ElementName=Nav}"
                                       Foreground="{DynamicResource App.TextPrimaryBrush}"/>
                        </Grid>
                    </Button>
                </Border>
            </ui:NavigationView.PaneFooter>

            <Grid RowDefinitions="Auto,*" Margin="12,40,12,12">

                <!-- Top bar: fetch dock on the left, active-group picker on the
                     right (theme toggle is in the nav pane footer now). -->
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,10">
                    <v:FetchDockView Grid.Column="0" DataContext="{Binding FetchDock}"/>

                    <!-- Connection-group picker: searchable AutoCompleteBox.
                         "All connections" sits at the top of the list and
                         clears the filter; type-to-search filters by group
                         name. MinimumPrefixLength=0 so a single click opens
                         the dropdown without typing first. -->
                    <Border x:Name="GroupSelector" Grid.Column="1" Margin="6,0,0,0"
                            VerticalAlignment="Center">
                        <AutoCompleteBox Width="220" MinHeight="30"
                                         ItemsSource="{Binding ConnectionGroupOptions}"
                                         SelectedItem="{Binding SelectedConnectionGroupOption, Mode=TwoWay}"
                                         FilterMode="Contains"
                                         MinimumPrefixLength="0"
                                         Watermark="Connection group"
                                         ToolTip.Tip="Active connection group — pickers across the app filter to this group's members. Pick 'All connections' to drop the filter.">
                            <AutoCompleteBox.ItemTemplate>
                                <DataTemplate DataType="vm:ConnectionGroupOption">
                                    <TextBlock Text="{Binding Name}" FontSize="12"/>
                                </DataTemplate>
                            </AutoCompleteBox.ItemTemplate>
                        </AutoCompleteBox>
                    </Border>
                </Grid>

                <ui:Frame x:Name="Host" Grid.Row="1" Padding="0"/>
            </Grid>
        </ui:NavigationView>

        <!-- Find overlay: browser-style Ctrl+F popup. Hidden by default,
             shown when Ctrl+F is pressed anywhere in the window. Type to
             filter the active view; Esc / X closes and clears. The
             overlay floats top-right over the active page so it never
             reflows the content underneath. -->
        <Border x:Name="FindOverlay"
                IsVisible="False"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,52,16,0"
                Padding="10,6"
                Background="{DynamicResource App.ElevatedBgBrush}"
                BorderBrush="{DynamicResource App.StrokeStrongBrush}"
                BorderThickness="1"
                CornerRadius="8"
                BoxShadow="0 6 20 0 #40000000">
            <Grid ColumnDefinitions="Auto,Auto,Auto" VerticalAlignment="Center">
                <TextBlock Grid.Column="0" Text="Find" FontSize="11" Opacity="0.7"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Grid.Column="1" x:Name="FindBox"
                         Width="240" MinHeight="26"
                         Watermark="Type to filter the current page"
                         KeyDown="OnFindBoxKeyDown"
                         TextChanged="OnFindBoxTextChanged"/>
                <Button  Grid.Column="2" Margin="6,0,0,0"
                         Padding="6,2" MinWidth="0" MinHeight="26"
                         Click="OnFindClose"
                         ToolTip.Tip="Close (Esc)">
                    <TextBlock Text="✕" FontSize="11"/>
                </Button>
            </Grid>
        </Border>

        <v:ToastHost x:Name="Toasts" DataContext="{Binding Services.Toasts}"/>
    </Panel>
</uiw:AppWindow>
