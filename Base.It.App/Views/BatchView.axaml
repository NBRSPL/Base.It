<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Base.It.App.ViewModels"
             xmlns:cfg="using:Base.It.Core.Config"
             x:Class="Base.It.App.Views.BatchView"
             x:DataType="vm:BatchViewModel">

    <!-- Rows:
         0  Profile bar (saved source/target presets)
         1  Source + badge
         2  Targets checklist
         3  Objects toolbar (file loader + Backup/Execute/Clear/Remove)
         4  DACPAC opt-in (collapsed when not configured)
         5  Status + name filters + counters
         6  Items card: QuickAdd row + DataGrid
         7  Status bar -->
    <DockPanel>
        <!-- Slim indeterminate progress bar docked to the top of the pane. -->
        <ProgressBar DockPanel.Dock="Top" Classes="pageLoader" IsVisible="{Binding IsBusy}"/>

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,*,Auto">

        <!-- Row 0: Profile bar — saved (source, targets) tuples. -->
        <Border Grid.Row="0" Classes="toolbar" Margin="0,0,0,6">
            <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*,Auto">
                <TextBlock Grid.Column="0" Text="Profile" VerticalAlignment="Center"
                           Margin="0,0,8,0" FontSize="12" Opacity="0.7"/>
                <ComboBox Grid.Column="1" Width="260"
                          ItemsSource="{Binding Profiles}"
                          SelectedItem="{Binding SelectedProfile}"
                          PlaceholderText="None — pick a saved pair">
                    <ComboBox.ItemTemplate>
                        <DataTemplate DataType="vm:EndpointProfile">
                            <TextBlock Text="{Binding Name}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Button   Grid.Column="2" Margin="6,0,0,0" Content="Save as profile…"
                          Command="{Binding SaveAsProfileCommand}"
                          ToolTip.Tip="Save the current source + ticked targets as a reusable profile."/>
                <Button   Grid.Column="3" Margin="4,0,0,0" Content="Delete"
                          Command="{Binding DeleteProfileCommand}"
                          IsEnabled="{Binding SelectedProfile, Converter={x:Static ObjectConverters.IsNotNull}}"
                          ToolTip.Tip="Delete the selected profile. Connections aren't affected."/>
                <!-- spacer @ col 4 -->
                <Button   Grid.Column="5" Content="⇄ Swap"
                          Command="{Binding SwapCommand}"
                          IsEnabled="{Binding CanSwap}"
                          ToolTip.Tip="Swap source with the single ticked target. Enabled only when exactly one target is ticked."/>
            </Grid>
        </Border>

        <!-- Row 1: source — single AutoCompleteBox (replaces cascading env / db dropdowns). -->
        <Border Grid.Row="1" Classes="toolbar" Margin="0,0,0,6">
            <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto">
                <TextBlock Grid.Column="0" Text="Source" VerticalAlignment="Center"
                           Margin="0,0,8,0" FontSize="12" Opacity="0.7"/>
                <AutoCompleteBox Grid.Column="1" x:Name="SourceBox" MinWidth="280"
                                 ItemsSource="{Binding Endpoints}"
                                 SelectedItem="{Binding SelectedSourceEndpoint, Mode=TwoWay}"
                                 Watermark="Type to filter — name, ENV or database">
                    <AutoCompleteBox.ItemTemplate>
                        <DataTemplate DataType="vm:EndpointPick">
                            <Grid ColumnDefinitions="Auto,*" Margin="0,2">
                                <Ellipse Grid.Column="0" Width="8" Height="8" VerticalAlignment="Center"
                                         Fill="{Binding Color, Converter={x:Static vm:ColorStringBrushConverter.Instance}}"
                                         Margin="0,0,8,0"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding Label}" FontSize="12"/>
                                    <TextBlock Text="{Binding SubLabel}"
                                               FontSize="10" Opacity="0.55"
                                               IsVisible="{Binding ShowSubLabel}"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </AutoCompleteBox.ItemTemplate>
                </AutoCompleteBox>
                <Border Grid.Column="2" Classes="badge"
                        Background="{Binding SourceProfile.Color, Converter={x:Static vm:ColorStringBrushConverter.Instance}}"
                        IsVisible="{Binding SourceProfile, Converter={x:Static ObjectConverters.IsNotNull}}"
                        VerticalAlignment="Center" Margin="8,0,0,0">
                    <TextBlock Text="{Binding SourceProfile.Label}"/>
                </Border>
                <!-- flex spacer @ col 3 -->
            </Grid>
        </Border>

        <!-- Targets — chip-style ToggleButtons with a filter / select-all /
             clear bar above. Mirrors the Sync pane so the two panes feel
             identical. FilteredTargets is the bound view; TargetFilter
             reactively narrows it. -->
        <Border Grid.Row="2" Classes="toolbar" Margin="0,0,0,6">
            <StackPanel Spacing="6">
                <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto">
                    <TextBlock Grid.Column="0" Text="Targets" VerticalAlignment="Center"
                               Margin="0,0,10,0" FontSize="12" Opacity="0.7"/>
                    <TextBox  Grid.Column="1" Width="220" MinHeight="28"
                              Text="{Binding TargetFilter, Mode=TwoWay}"
                              Watermark="Filter — name, ENV or database"/>
                    <TextBlock Grid.Column="2" VerticalAlignment="Center" Margin="12,0,12,0"
                               FontSize="11" Opacity="0.55"
                               Text="{Binding TargetSelectedCount, StringFormat='{}{0} selected'}"/>
                    <Button   Grid.Column="3" Content="Select all visible"
                              Command="{Binding SelectAllVisibleTargetsCommand}"
                              ToolTip.Tip="Tick every target currently shown by the filter."/>
                    <Button   Grid.Column="4" Margin="4,0,0,0" Content="Clear"
                              Command="{Binding ClearTargetsCommand}"
                              ToolTip.Tip="Untick every target — even ones hidden by the filter."/>
                </Grid>
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding FilteredTargets}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:TargetPickVm">
                                <ToggleButton Classes="chip"
                                              Content="{Binding Label}"
                                              IsChecked="{Binding IsChecked, Mode=TwoWay}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>
        </Border>

        <!-- Objects toolbar — manual-object input is gone; quick-add now
             lives as the first editable row above the items grid. The
             file loader keeps Load + Backup + Execute + Clear + Remove. -->
        <Border Grid.Row="3" Classes="toolbar" Margin="0,0,0,6">
            <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,*">
                <TextBox Grid.Column="0" Width="320" Text="{Binding FilePath}"
                         Watermark=".csv / .xlsx">
                    <TextBox.KeyBindings>
                        <KeyBinding Gesture="Enter" Command="{Binding LoadFromFileCommand}"/>
                    </TextBox.KeyBindings>
                </TextBox>
                <Button  Grid.Column="1" Margin="4,0,0,0" MinWidth="64" Content="Load"
                         Command="{Binding LoadFromFileCommand}"/>
                <Button  Grid.Column="2" Margin="12,0,0,0" MinWidth="72" Content="Backup"
                         Command="{Binding BackupCommand}" IsEnabled="{Binding !IsBusy}"
                         ToolTip.Tip="Capture each row from source + ticked targets without altering anything."/>
                <Button  Grid.Column="3" Margin="4,0,0,0" MinWidth="84" Content="Execute" Classes="accent"
                         Command="{Binding ExecuteCommand}" IsEnabled="{Binding !IsBusy}"/>
                <Button  Grid.Column="4" Margin="4,0,0,0" MinWidth="64" Content="Clear"
                         Command="{Binding ClearCommand}"
                         ToolTip.Tip="Remove every row from the list."/>
                <Button  Grid.Column="5" Margin="4,0,0,0" MinWidth="120" Content="Remove selected"
                         Command="{Binding RemoveCheckedCommand}"
                         ToolTip.Tip="Remove rows whose checkbox (left-most column) is ticked."/>
            </Grid>
        </Border>

        <!-- DACPAC opt-in -->
        <Border Grid.Row="4" Classes="toolbar" Margin="0,0,0,6"
                IsVisible="{Binding DacpacConfigured}">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <CheckBox Grid.Column="0" Content="Write to DACPAC folder"
                          IsChecked="{Binding StageAsDacpacBranch}"
                          IsEnabled="{Binding !IsBusy}"
                          ToolTip.Tip="After each successful sync, write the object's definition to the configured DACPAC / SSDT folder. No git actions are taken — commit the changes yourself."/>
                <TextBlock Grid.Column="2" FontSize="11" Opacity="0.55" VerticalAlignment="Center"
                           Text="configured in Settings → DACPAC"/>
            </Grid>
        </Border>

        <!-- Status filter + name find-box + live OK/Fail counters.
             Ctrl+F (UserControl-level) focuses the name find-box. -->
        <Border Grid.Row="5" Classes="toolbar" Margin="0,0,0,6">
            <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto">
                <TextBlock Grid.Column="0" Text="Status" VerticalAlignment="Center"
                           Margin="0,0,8,0" FontSize="12" Opacity="0.7"/>
                <ComboBox Grid.Column="1" Width="140"
                          ItemsSource="{Binding StatusFilterOptions}"
                          SelectedItem="{Binding StatusFilter}"/>
                <TextBlock Grid.Column="2" Text="Find" VerticalAlignment="Center"
                           Margin="14,0,8,0" FontSize="12" Opacity="0.7"/>
                <TextBox Grid.Column="3" x:Name="NameFilterBox" Width="200"
                         Text="{Binding NameFilter, Mode=TwoWay}"
                         Watermark="Filter by name (Ctrl+F)"/>
                <TextBlock Grid.Column="4" VerticalAlignment="Center" Margin="12,0,12,0"
                           FontSize="11" Opacity="0.55"
                           Text="Rows matching status AND name. Blank = no filter."
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock Grid.Column="5" VerticalAlignment="Center" Margin="0,0,12,0"
                           Text="{Binding SuccessCount, StringFormat='OK: {0}'}"
                           Foreground="{DynamicResource SystemFillColorSuccessBrush}" FontSize="11"/>
                <TextBlock Grid.Column="6" VerticalAlignment="Center"
                           Text="{Binding FailCount, StringFormat='Fail: {0}'}"
                           Foreground="{DynamicResource SystemFillColorCriticalBrush}" FontSize="11"/>
            </Grid>
        </Border>

        <!-- Grid: Excel-like behaviour — drag/Shift/Ctrl multi-select via
             SelectionMode=Extended, Ctrl+C copies the selection to the
             clipboard (ClipboardCopyMode=ExcludeHeader), Ctrl+V pastes a
             newline-separated list of names (handler in code-behind),
             Delete removes the selected rows.

             The QuickAdd box sits flush at the top of the same card so
             it visually reads as the editable first row. Type a name +
             Enter to add it; pasting multi-line text fans out into one
             row per line. The Manual Object box + Add button are gone —
             this replaces both. -->
        <Border Grid.Row="6" Classes="card" Padding="0" ClipToBounds="True">
          <DockPanel>
            <!-- The QuickAdd row sits above the DataGrid header but its
                 column structure mirrors the grid (44,50,*,100,2*) so the
                 "+" indicator lands right under the # column header and
                 the input lines up with the Object-name column. Visually
                 it reads as the always-ready first row of the list. -->
            <Border DockPanel.Dock="Top"
                    BorderThickness="0,0,0,1"
                    BorderBrush="{DynamicResource App.StrokeBrush}"
                    Background="{DynamicResource App.ToolbarBgBrush}"
                    Padding="0,6">
                <Grid ColumnDefinitions="44,50,*,100,2*">
                    <!-- col 0: empty (matches the checkbox column) -->
                    <TextBlock Grid.Column="1" Text="＋"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="13" FontWeight="Bold"
                               Foreground="{DynamicResource App.SuccessBrush}"
                               ToolTip.Tip="Type a name + Enter to add. Paste a multi-line list to add many at once."/>
                    <TextBox Grid.Column="2" Grid.ColumnSpan="3"
                             x:Name="QuickAddBox"
                             BorderThickness="0" Background="Transparent"
                             Padding="0,2" MinHeight="24"
                             VerticalContentAlignment="Center"
                             Watermark="Type or paste object name(s) — Enter to add"
                             KeyDown="OnQuickAddKeyDown"
                             PastingFromClipboard="OnQuickAddPaste"/>
                </Grid>
            </Border>
            <DataGrid x:Name="ItemsGrid" ItemsSource="{Binding FilteredItems}" AutoGenerateColumns="False"
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                      CanUserReorderColumns="False"
                      SelectionMode="Extended"
                      ClipboardCopyMode="ExcludeHeader"
                      KeyDown="OnGridKeyDown">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="" Width="44" CanUserResize="False" CanUserSort="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="vm:BatchItem">
                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Margin="0" Padding="0" MinWidth="0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="#"           Binding="{Binding Index}"   Width="50"  IsReadOnly="True"/>
                    <DataGridTextColumn Header="Object name" Binding="{Binding Name}"    Width="*"/>
                    <DataGridTextColumn Header="Status"      Binding="{Binding Status}"  Width="100" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Message"     Binding="{Binding Message}" Width="2*"  IsReadOnly="True"/>
                </DataGrid.Columns>
            </DataGrid>
          </DockPanel>
        </Border>

        <Border Grid.Row="7" Classes="pageStatus">
            <TextBlock Text="{Binding Status}" TextWrapping="Wrap"/>
        </Border>
    </Grid>
    </DockPanel>
</UserControl>
