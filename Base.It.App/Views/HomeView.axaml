<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Base.It.App.ViewModels"
             x:Class="Base.It.App.Views.HomeView"
             x:DataType="vm:HomeViewModel">

    <!-- Single-screen layout: no outer ScrollViewer so everything fits
         without vertical scrolling at the window's default 1240x760.
         Grid rows are Auto × 4 to keep the sections pinned to the top
         and allow the bottom card to absorb any leftover height. -->
    <Grid Margin="6,4,6,6" RowDefinitions="Auto,Auto,Auto,Auto,*">

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="2" Margin="0,0,0,10">
            <TextBlock Text="Welcome to Base.it" Classes="pageTitle"/>
            <TextBlock Classes="subtle" TextWrapping="Wrap"
                       Text="A fast, safe way to compare and sync SQL objects across your environments. Follow the three steps below to get started."/>
        </StackPanel>

        <!-- Quick status strip -->
        <Border Grid.Row="1" Classes="cardElevated" Padding="14,10" Margin="0,0,0,10">
            <Grid ColumnDefinitions="*,*,*">
                <StackPanel Grid.Column="0" Spacing="1">
                    <TextBlock Text="Connections" Classes="subtle"/>
                    <TextBlock Text="{Binding ConnectionCount}" FontSize="18" FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="1">
                    <TextBlock Text="Groups" Classes="subtle"/>
                    <TextBlock Text="{Binding GroupCount}" FontSize="18" FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Spacing="1">
                    <TextBlock Text="Active group" Classes="subtle"/>
                    <TextBlock Text="{Binding ActiveGroupName}" FontSize="13" FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Guided steps -->
        <Grid Grid.Row="2" ColumnDefinitions="*,*,*" Margin="0,0,0,10">
            <!-- Step 1 -->
            <Border Grid.Column="0" Classes="card" Margin="0,0,6,0" Padding="12,10">
                <StackPanel Spacing="6">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Border Grid.Column="0" Width="22" Height="22" CornerRadius="11"
                                Background="{DynamicResource App.AccentBrush}">
                            <TextBlock Text="1" Foreground="{DynamicResource App.OnAccentBrush}"
                                       FontWeight="Bold" HorizontalAlignment="Center"
                                       VerticalAlignment="Center" FontSize="11"/>
                        </Border>
                        <TextBlock Grid.Column="1" Text="Add connections" FontWeight="SemiBold"
                                   FontSize="13" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        <Border Grid.Column="2" Classes="tag" IsVisible="{Binding Step1Done}">
                            <TextBlock Text="done"/>
                        </Border>
                    </Grid>
                    <TextBlock Classes="subtle" TextWrapping="Wrap" FontSize="11"
                               Text="Tell Base.it how to reach your SQL servers. Each connection is one (environment, database) pair."/>
                    <Button Content="Open Settings" Command="{Binding GoSettingsCommand}"
                            Classes="accent" HorizontalAlignment="Left" MinHeight="26" Padding="10,2"/>
                </StackPanel>
            </Border>
            <!-- Step 2 -->
            <Border Grid.Column="1" Classes="card" Margin="3,0" Padding="12,10">
                <StackPanel Spacing="6">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Border Grid.Column="0" Width="22" Height="22" CornerRadius="11"
                                Background="{DynamicResource App.AccentBrush}">
                            <TextBlock Text="2" Foreground="{DynamicResource App.OnAccentBrush}"
                                       FontWeight="Bold" HorizontalAlignment="Center"
                                       VerticalAlignment="Center" FontSize="11"/>
                        </Border>
                        <TextBlock Grid.Column="1" Text="Bundle into groups" FontWeight="SemiBold"
                                   FontSize="13" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        <Border Grid.Column="2" Classes="tag" IsVisible="{Binding Step2Done}">
                            <TextBlock Text="done"/>
                        </Border>
                    </Grid>
                    <TextBlock Classes="subtle" TextWrapping="Wrap" FontSize="11"
                               Text="Logical bundles of related connections. The top-bar picker makes one active at a time so Sync/Batch/Watch only show that group's members."/>
                    <Button Content="Manage groups" Command="{Binding GoSettingsCommand}"
                            IsEnabled="{Binding HasConnections}"
                            HorizontalAlignment="Left" MinHeight="26" Padding="10,2"/>
                </StackPanel>
            </Border>
            <!-- Step 3 -->
            <Border Grid.Column="2" Classes="card" Margin="6,0,0,0" Padding="12,10">
                <StackPanel Spacing="6">
                    <Grid ColumnDefinitions="Auto,*">
                        <Border Grid.Column="0" Width="22" Height="22" CornerRadius="11"
                                Background="{DynamicResource App.AccentBrush}">
                            <TextBlock Text="3" Foreground="{DynamicResource App.OnAccentBrush}"
                                       FontWeight="Bold" HorizontalAlignment="Center"
                                       VerticalAlignment="Center" FontSize="11"/>
                        </Border>
                        <TextBlock Grid.Column="1" Text="Compare or sync" FontWeight="SemiBold"
                                   FontSize="13" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </Grid>
                    <TextBlock Classes="subtle" TextWrapping="Wrap" FontSize="11"
                               Text="Compare diffs two envs, Sync pushes one object, Batch pushes many, Watch polls for drift. Every run is backed up first."/>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <Button Content="Compare" Command="{Binding GoCompareCommand}" IsEnabled="{Binding Step3Enabled}"
                                MinHeight="26" Padding="10,2"/>
                        <Button Content="Sync"    Command="{Binding GoSyncCommand}"    IsEnabled="{Binding Step3Enabled}"
                                MinHeight="26" Padding="10,2"/>
                        <Button Content="Batch"   Command="{Binding GoBatchCommand}"   IsEnabled="{Binding Step3Enabled}"
                                MinHeight="26" Padding="10,2"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Jump-to shortcuts -->
        <Grid Grid.Row="3" ColumnDefinitions="*,*,*,*,*" Margin="0,0,0,10">
            <Button Grid.Column="0" Command="{Binding GoCompareCommand}" IsEnabled="{Binding Step3Enabled}"
                    Margin="0,0,4,0" Padding="10,8" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                <StackPanel Spacing="1">
                    <TextBlock Text="Compare" FontWeight="SemiBold" FontSize="12"/>
                    <TextBlock Text="diff two envs" Classes="subtle" TextWrapping="Wrap"/>
                </StackPanel>
            </Button>
            <Button Grid.Column="1" Command="{Binding GoSyncCommand}" IsEnabled="{Binding Step3Enabled}"
                    Margin="2,0" Padding="10,8" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                <StackPanel Spacing="1">
                    <TextBlock Text="Sync" FontWeight="SemiBold" FontSize="12"/>
                    <TextBlock Text="push one object" Classes="subtle" TextWrapping="Wrap"/>
                </StackPanel>
            </Button>
            <Button Grid.Column="2" Command="{Binding GoBatchCommand}" IsEnabled="{Binding Step3Enabled}"
                    Margin="2,0" Padding="10,8" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                <StackPanel Spacing="1">
                    <TextBlock Text="Batch" FontWeight="SemiBold" FontSize="12"/>
                    <TextBlock Text="push many" Classes="subtle" TextWrapping="Wrap"/>
                </StackPanel>
            </Button>
            <Button Grid.Column="3" Command="{Binding GoWatchCommand}" IsEnabled="{Binding Step3Enabled}"
                    Margin="2,0" Padding="10,8" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                <StackPanel Spacing="1">
                    <TextBlock Text="Watch" FontWeight="SemiBold" FontSize="12"/>
                    <TextBlock Text="poll for drift" Classes="subtle" TextWrapping="Wrap"/>
                </StackPanel>
            </Button>
            <Button Grid.Column="4" Command="{Binding GoQueryCommand}" IsEnabled="{Binding Step3Enabled}"
                    Margin="4,0,0,0" Padding="10,8" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                <StackPanel Spacing="1">
                    <TextBlock Text="Query" FontWeight="SemiBold" FontSize="12"/>
                    <TextBlock Text="ad-hoc SQL" Classes="subtle" TextWrapping="Wrap"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- Paths card — compact 2×2 layout, never overwrites note inline. -->
        <Border Grid.Row="4" Classes="card" Padding="14,10" VerticalAlignment="Top">
            <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,Auto,Auto">
                <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Paths" Classes="sectionTitle"
                           Margin="0,0,0,6"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Backups" Classes="subtle"
                           VerticalAlignment="Center"/>
                <SelectableTextBlock Grid.Row="1" Grid.Column="1" Classes="mono" FontSize="12"
                                     VerticalAlignment="Center"
                                     Text="{Binding BackupRoot}"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="DACPAC" Classes="subtle"
                           VerticalAlignment="Center" Margin="0,4,0,0"/>
                <SelectableTextBlock Grid.Row="2" Grid.Column="1" Classes="mono" FontSize="12"
                                     VerticalAlignment="Center" Margin="0,4,0,0"
                                     Text="{Binding DacpacPath}"
                                     Foreground="{DynamicResource App.TextSecondaryBrush}"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
