<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Base.It.App.ViewModels"
             xmlns:cfg="using:Base.It.Core.Config"
             x:Class="Base.It.App.Views.QueryView"
             x:DataType="vm:QueryViewModel">

    <DockPanel>
        <ProgressBar DockPanel.Dock="Top" Classes="pageLoader" IsVisible="{Binding IsBusy}"/>

    <!-- Rows: toolbar | query | splitter | results | status.
         Query and Results are *,* so they share the leftover height
         50/50 by default; the GridSplitter between them is draggable
         either way. MinHeight=80 on each so neither pane can be
         dragged to invisibility. -->
    <Grid RowDefinitions="Auto,*,Auto,*,Auto">

        <Border Grid.Row="0" Classes="toolbar" Margin="0,0,0,6">
            <Grid ColumnDefinitions="170,Auto,*,Auto">
                <ComboBox Grid.Column="0" ItemsSource="{Binding Databases}"
                          SelectedItem="{Binding Database}" PlaceholderText="Database"
                          HorizontalAlignment="Stretch"/>
                <ItemsControl Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center"
                              ItemsSource="{Binding Envs}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal" Spacing="10"/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:EnvToggle">
                            <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <ItemsControl Grid.Column="2" Margin="10,0,0,0" HorizontalAlignment="Right"
                              VerticalAlignment="Center" ItemsSource="{Binding InvolvedConnections}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal" Spacing="4"/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="cfg:EnvironmentConfig">
                            <Border Classes="badge"
                                    Background="{Binding Color, Converter={x:Static vm:ColorStringBrushConverter.Instance}}">
                                <TextBlock Text="{Binding Label}"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Button Grid.Column="3" Margin="6,0,0,0" Content="Run" Classes="accent"
                        Command="{Binding RunCommand}" IsEnabled="{Binding !IsBusy}"
                        ToolTip.Tip="Pick a database, check environments, type T-SQL, Run. SELECT shows columns and rows; DML/DDL shows rows affected. Per-env output labelled below."/>
            </Grid>
        </Border>

        <!-- Query editor -->
        <Border Grid.Row="1" Classes="card" Padding="0" MinHeight="80">
            <TextBox Text="{Binding Query}" AcceptsReturn="True" AcceptsTab="True"
                     TextWrapping="NoWrap" Classes="mono" FontSize="13"
                     Watermark="T-SQL"
                     VerticalContentAlignment="Top" Padding="10,6"
                     BorderThickness="0" Background="Transparent"/>
        </Border>

        <!-- Drag handle between query and results. 6px tall, transparent
             background but the splitter still hit-tests; cursor turns
             into the row-resize affordance on hover. -->
        <GridSplitter Grid.Row="2"
                      Height="6"
                      HorizontalAlignment="Stretch"
                      ResizeDirection="Rows"
                      Background="Transparent"
                      ShowsPreview="False"
                      Margin="0,4"/>

        <!-- Results area: the display -->
        <Border Grid.Row="3" Classes="card" Padding="0" MinHeight="80">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Text="Results" Classes="sectionTitle"
                           Margin="10,8,10,4"/>
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto">
                    <SelectableTextBlock Text="{Binding Results}" Classes="mono"
                                         Padding="10,4,10,8" TextWrapping="NoWrap"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <Border Grid.Row="4" Classes="pageStatus">
            <TextBlock Text="{Binding Status}"/>
        </Border>
    </Grid>
    </DockPanel>
</UserControl>
