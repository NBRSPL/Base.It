<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Base.It.App.ViewModels"
        x:Class="Base.It.App.Views.WatchGroupEditorWindow"
        x:DataType="vm:WatchGroupEditorViewModel"
        Width="620" Height="640"
        MinWidth="520" MinHeight="520"
        WindowStartupLocation="CenterOwner"
        Title="Watch Group">

    <Border Padding="16" Classes="card" Margin="12">
        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,*,Auto,Auto"
              ColumnDefinitions="140,*">

            <!-- Name -->
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Name" VerticalAlignment="Center"/>
            <TextBox   Grid.Row="0" Grid.Column="1" Text="{Binding Name}" Margin="0,0,0,8"/>

            <!-- Source env + db -->
            <TextBlock Grid.Row="1" Grid.Column="0" Text="Source" VerticalAlignment="Center"/>
            <Grid Grid.Row="1" Grid.Column="1" ColumnDefinitions="*,8,*" Margin="0,0,0,8">
                <ComboBox  Grid.Column="0" ItemsSource="{Binding Environments}"
                           SelectedItem="{Binding SourceEnv}" PlaceholderText="Environment"
                           HorizontalAlignment="Stretch"/>
                <ComboBox  Grid.Column="2" ItemsSource="{Binding Databases}"
                           SelectedItem="{Binding SourceDatabase}" PlaceholderText="Database"
                           HorizontalAlignment="Stretch"/>
            </Grid>

            <!-- Targets header + add -->
            <TextBlock Grid.Row="2" Grid.Column="0" Text="Targets" VerticalAlignment="Top" Margin="0,6,0,0"/>
            <Grid Grid.Row="2" Grid.Column="1" ColumnDefinitions="*,Auto" Margin="0,0,0,4">
                <TextBlock Grid.Column="0" FontSize="11" Opacity="0.6"
                           VerticalAlignment="Center" TextWrapping="Wrap"
                           Text="One or more endpoints to compare against. Each target can live in a different database — same-env cross-db is supported."/>
                <Button Grid.Column="1" Content="+ Add target"
                        Command="{Binding AddTargetCommand}"/>
            </Grid>

            <!-- Target list -->
            <Border Grid.Row="3" Grid.Column="1" BorderThickness="1"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    CornerRadius="4" Margin="0,0,0,8" Padding="4" MaxHeight="180">
                <ScrollViewer>
                    <ItemsControl ItemsSource="{Binding Targets}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:TargetEditVm">
                                <Grid ColumnDefinitions="*,6,*,6,Auto" Margin="2,2">
                                    <ComboBox Grid.Column="0" ItemsSource="{Binding Environments}"
                                              SelectedItem="{Binding Environment}"
                                              PlaceholderText="Environment"
                                              HorizontalAlignment="Stretch"/>
                                    <ComboBox Grid.Column="2" ItemsSource="{Binding Databases}"
                                              SelectedItem="{Binding Database}"
                                              PlaceholderText="Database"
                                              HorizontalAlignment="Stretch"/>
                                    <Button Grid.Column="4" Content="&#x2715;"
                                            Padding="8,2" MinWidth="0"
                                            Command="{Binding $parent[ItemsControl].((vm:WatchGroupEditorViewModel)DataContext).RemoveTargetCommand}"
                                            CommandParameter="{Binding}"
                                            ToolTip.Tip="Remove this target"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <!-- Interval + enabled -->
            <TextBlock Grid.Row="4" Grid.Column="0" Text="Interval (s)" VerticalAlignment="Center"/>
            <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" Spacing="12" Margin="0,0,0,8">
                <NumericUpDown Value="{Binding IntervalSeconds}" Minimum="5" Maximum="3600"
                               FormatString="0" Width="120"/>
                <CheckBox Content="Enabled" IsChecked="{Binding Enabled}" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Objects label -->
            <TextBlock Grid.Row="5" Grid.Column="0" Text="Objects" VerticalAlignment="Top" Margin="0,4,0,0"/>
            <StackPanel Grid.Row="5" Grid.Column="1" Spacing="2" Margin="0,0,0,4">
                <TextBlock Text="One per line. Schema optional — 'dbo' assumed."
                           FontSize="11" Opacity="0.6" FontStyle="Italic"/>
                <TextBlock Text="Leave empty to watch EVERY object of the active object types. Toggle types on the Watch pane to scope the scan."
                           FontSize="11" Opacity="0.6" FontStyle="Italic" TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Objects textbox -->
            <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding ObjectsText}"
                     AcceptsReturn="True" TextWrapping="Wrap"
                     VerticalContentAlignment="Top" Margin="0,0,0,8"/>

            <!-- Validation + buttons -->
            <TextBlock Grid.Row="7" Grid.ColumnSpan="2" Text="{Binding ValidationError}"
                       Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                       FontSize="12" Margin="0,0,0,8"
                       IsVisible="{Binding ValidationError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

            <StackPanel Grid.Row="8" Grid.ColumnSpan="2" Orientation="Horizontal"
                        HorizontalAlignment="Right" Spacing="8">
                <Button Content="Cancel" Command="{Binding CancelCommand}"/>
                <Button Content="Save"   Command="{Binding SaveCommand}"   Classes="accent"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
